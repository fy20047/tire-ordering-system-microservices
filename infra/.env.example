DB_HOST=localhost
DB_PORT=3307
DB_NAME=tire_shop
DB_USERNAME=app
DB_PASSWORD=change_me
DB_ROOT_PASSWORD=change_me
ADMIN_USERNAME=change_me
ADMIN_PASSWORD=change_me
# RS256 金鑰（請填完整 PEM 字串，建議存成單行並保留 PEM 標頭尾）
JWT_PRIVATE_KEY=replace_with_rs256_private_key_pem
JWT_PUBLIC_KEY=replace_with_rs256_public_key_pem
JWT_EXPIRATION_SECONDS=3600
JWT_REFRESH_EXPIRATION_SECONDS=1209600
JWT_REFRESH_COOKIE_NAME=refreshToken
JWT_REFRESH_COOKIE_SECURE=false
JWT_REFRESH_COOKIE_SAME_SITE=Lax
BACKEND_AUTH_ENDPOINTS_ENABLED=false
